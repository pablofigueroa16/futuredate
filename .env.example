# Copia este archivo a .env y rellena los valores. NUNCA subas .env al repo.

# --- Neon (Postgres) ---
# Connection string "pooled" del proyecto Neon (T-0.7)
DATABASE_URL=

# --- Google OAuth (T-0.6) ---
# Credenciales OAuth (tipo "Web") desde Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- better-auth ---
# Secreto para firmar sesiones. Genera uno con: openssl rand -base64 32
BETTER_AUTH_SECRET=
# URL base de la app (dev). En prod, la URL pública.
BETTER_AUTH_URL=http://localhost:3000
